# Kopiraj u .env.local i popuni pravim vrednostima — .env.local se NE komituje (vidi .gitignore).

# OpenRouter (AI konzilijum + istraživanje). Ključ: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Supabase (auth + bankroll baza). Iz Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Napomena: SUPABASE i VERCEL management tokeni su bili samo za jednokratno postavljanje
# infrastrukture i NE treba da stoje u produkciji.
